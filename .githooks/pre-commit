#!/usr/bin/env bash
set -euo pipefail
# Auto-generated by scripts/recommended-config.py --format hook --fixable-lints fixable-lints.cargo.toml

# Use rg (ripgrep) for pattern matching if available, fall back to grep -E.
if command -v rg &>/dev/null; then
  _grep() { rg "$@"; }
else
  _grep() { grep -E "$@"; }
fi

# 0. Isolate staged content — stash unstaged changes so tools only see what
#    will be committed. A unique name lets us find this entry even if the hook
#    fails and is re-run.
staged=$(git diff --cached --name-only --diff-filter=ACM)
[[ -z "$staged" ]] && exit 0

# Skip entirely when no Rust-relevant files are staged (e.g. docs-only commits).
echo "$staged" | _grep '\.rs$|Cargo\.toml$' || exit 0

stash_name="pre-commit-$(date +%s)"
git stash push --keep-index --include-untracked -q -m "$stash_name"
# Restore the user's working tree unconditionally. Plain `git stash pop`
# merges, which conflicts when tools mutated the same files. Instead:
#   (a) snapshot the fixed index to a tree object
#   (b) hard-reset working tree + index to HEAD (the stash's base)
#   (c) pop the stash — applies cleanly because the base matches
#   (d) re-read the fixed index and checkout fixed files into working tree
trap '
  if git stash list | grep -qF "$stash_name"; then
    fixed_tree=$(git write-tree)
    git reset --hard -q HEAD
    git stash pop -q
    if [[ -n "${fixed_tree:-}" ]]; then
      git read-tree "$fixed_tree"
      echo "$staged" | xargs -r git checkout-index -f --
    fi
  fi
' EXIT

# 1. Auto-fix idioms — always-correct machine-applicable fixes applied silently.
#    Fixed-point loop: --fix skips fixes with overlapping spans, so a single
#    pass can leave unfixed code. Loop until clippy reports no more fixes.
for (( i=0; i<5; i++ )); do
  output=$(cargo clippy --fix --allow-dirty --allow-staged -- \
  -W clippy::all \
  -W clippy::pedantic \
  -W clippy::nursery \
  -W clippy::alloc_instead_of_core \
  -W clippy::allow_attributes \
  -W clippy::as_pointer_underscore \
  -W clippy::as_underscore \
  -W clippy::assertions_on_result_states \
  -W clippy::dbg_macro \
  -W clippy::deref_by_slicing \
  -W clippy::doc_include_without_cfg \
  -W clippy::get_unwrap \
  -W clippy::if_then_some_else_none \
  -W clippy::lossy_float_literal \
  -W clippy::missing_asserts_for_indexing \
  -W clippy::needless_raw_strings \
  -W clippy::non_ascii_literal \
  -W clippy::non_zero_suggestions \
  -W clippy::precedence_bits \
  -W clippy::pub_with_shorthand \
  -W clippy::rest_pat_in_fully_bound_structs \
  -W clippy::return_and_then \
  -W clippy::semicolon_outside_block \
  -W clippy::std_instead_of_alloc \
  -W clippy::std_instead_of_core \
  -W clippy::str_to_string \
  -W clippy::string_lit_chars_any \
  -W clippy::try_err \
  -W clippy::unnecessary_safety_comment \
  -W clippy::unseparated_literal_suffix \
  -W clippy::unused_trait_names 2>&1)
  echo "$output" | _grep -q 'Fixed' || break
done
# Print only if there are unresolved diagnostics (errors or named warnings).
if echo "$output" | _grep -q '^error|^warning\['; then
  echo "$output"
fi

# 2. Strip decorative comment dividers (language-agnostic — works on any //-comment language).
echo "$staged" | _grep '\.(rs|ts|tsx|js|jsx)$' | xargs -r awk -i inplace -f scripts/strip-decorative-comments.awk

# 3. Check for debug remnants — runs after auto-fix so cleaned-up code is checked too.
cargo dylint debug_remnants --warn || true

# 4. Format only staged .rs files.
echo "$staged" | _grep '\.rs$' | xargs -r rustfmt

# 5. Re-stage only originally-staged files modified by auto-fix and formatting.
echo "$staged" | xargs -r git add

# 6. Check for banned crates — catches additions at the point they enter Cargo.toml.
declare -A BANNED=(
  [lazy_static]="use std::sync::LazyLock (Rust 1.80+)"
  [once_cell]="use std::sync::OnceLock / LazyLock (Rust 1.70+/1.80+)"
  [failure]="use thiserror for libraries, anyhow for applications"
  [dashmap]="use RwLock<HashMap> — DashMap deadlocks when a Ref is held across map calls"
  [openssl]="use rustls"
  [md5]="MD5 is cryptographically broken; use SHA-256 or SHA-3"
  [sha1]="SHA-1 collision resistance is broken; use SHA-256 or SHA-3"
)

rc=0
while IFS= read -r toml; do
  for crate in "${!BANNED[@]}"; do
    if _grep -q "^[[:space:]]*${crate}[[:space:]]*(=|\{)" "$toml"; then
      echo "banned dependency '${crate}' in ${toml} — ${BANNED[$crate]}"
      rc=1
    fi
  done
done < <(echo "$staged" | _grep 'Cargo\.toml$')

exit $rc
